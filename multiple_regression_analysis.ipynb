import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import statsmodels.api as sm
from statsmodels.stats.outliers_influence import variance_inflation_factor

# Set plot style
sns.set_theme(style="whitegrid")

# Load the dataset (Uncomment the line below when running locally)
# df = pd.read_csv('marketing_sales_data.csv')

# --- FOR DEMONSTRATION: Creating synthetic data matching your schema ---
np.random.seed(42)
n_samples = 200
tv = np.random.normal(100, 30, n_samples)
radio = np.random.normal(40, 15, n_samples)
social_media = 0.5 * radio + np.random.normal(10, 5, n_samples) # Induced mild multicollinearity
sales = 5 + 3.5 * tv + 1.8 * radio + 0.2 * social_media + np.random.normal(0, 10, n_samples)

df = pd.DataFrame({'TV': tv, 'Radio': radio, 'Social Media': social_media, 'Sales': sales})
# ----------------------------------------------------------------------

# Display basic information
print("--- Dataset Summary ---")
print(df.info())
print("\n--- First 5 Rows ---")
print(df.head())
print("--- Descriptive Statistics ---")
print(df.describe())

# 1. Correlation Matrix Plot
plt.figure(figsize=(8, 6))
sns.heatmap(df.corr(), annot=True, cmap='Blues', fmt='.2f')
plt.title('Correlation Matrix of Marketing Channels')
plt.show()

# 2. Check for Multicollinearity using Variance Inflation Factor (VIF)
X_vif = df[['TV', 'Radio', 'Social Media']]
X_vif_const = sm.add_constant(X_vif) # VIF requires a constant column

vif_data = pd.DataFrame()
vif_data["Feature"] = X_vif.columns
vif_data["VIF"] = [variance_inflation_factor(X_vif_const.values, i+1) for i in range(X_vif.shape[1])]

print("\n--- Variance Inflation Factors (VIF) ---")
print(vif_data)
# Define features and target
X = df[['TV', 'Radio', 'Social Media']]
y = df['Sales']

# Add constant for intercept estimation
X = sm.add_constant(X)

# Fit OLS Model
model = sm.OLS(y, X).fit()

# Print full summary stats
print(model.summary())

# Extract residuals and predicted values
residuals = model.resid
fitted_values = model.fittedvalues

fig, axes = plt.subplots(1, 3, figsize=(18, 5))

# 1. Linearity & Homoscedasticity: Residuals vs Fitted
sns.scatterplot(x=fitted_values, y=residuals, ax=axes[0], alpha=0.7)
axes[0].axhline(y=0, color='r', linestyle='--')
axes[0].set_title('Residuals vs Fitted (Linearity/Homoscedasticity)')
axes[0].set_xlabel('Fitted Values')
axes[0].set_ylabel('Residuals')

# 2. Normality: Q-Q Plot
sm.qqplot(residuals, line='45', fit=True, ax=axes[1])
axes[1].set_title('Normal Q-Q Plot')

# 3. Normality: Residual Histogram
sns.histplot(residuals, kde=True, ax=axes[2], color='purple')
axes[2].set_title('Distribution of Residuals')

plt.tight_layout()
plt.show()
